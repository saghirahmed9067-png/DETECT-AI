{
  "framework": "nextjs",
  "buildCommand": "cd frontend && npm run build",
  "outputDirectory": "frontend/.next",
  "installCommand": "cd frontend && npm ci --legacy-peer-deps",
  "rootDirectory": ".",
  "regions": ["iad1"],
  "env": {
    "NEXT_TELEMETRY_DISABLED": "1"
  },
  "functions": {
    "frontend/app/api/detect/image/route.ts":  { "maxDuration": 60 },
    "frontend/app/api/detect/video/route.ts":  { "maxDuration": 60 },
    "frontend/app/api/detect/audio/route.ts":  { "maxDuration": 60 },
    "frontend/app/api/detect/text/route.ts":   { "maxDuration": 60 },
    "frontend/app/api/detect/pdf/route.ts":    { "maxDuration": 120 },
    "frontend/app/api/chat/route.ts":          { "maxDuration": 120 },
    "frontend/app/api/scraper/route.ts":       { "maxDuration": 60 }
  }
}
