# ════════════════════════════════════════════════════════════════════════════
# Aiscern Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git
# ════════════════════════════════════════════════════════════════════════════

# ── Clerk Auth (REQUIRED — app will crash without these) ─────────────────────
# Get from: https://dashboard.clerk.com → Your App → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_SECRET_KEY=sk_live_...

# ── Supabase (REQUIRED — scan history, profiles, reviews) ────────────────────
# Get from: https://supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...  # server-only, never expose to client

# ── HuggingFace (REQUIRED — AI detection models) ─────────────────────────────
# Get from: https://huggingface.co/settings/tokens
# Needs: read access to models + write access to push dataset
HUGGINGFACE_API_TOKEN=hf_...

# ── NVIDIA NIM (optional — enables video deepfake frame analysis) ─────────────
# Get from: https://build.nvidia.com → API Keys
# Without this, video detection falls back to metadata heuristics
NVIDIA_API_KEY=nvapi-...

# ── Cloudflare (optional — pipeline stats dashboard in admin) ─────────────────
# Get from: https://dash.cloudflare.com → My Profile → API Tokens
# Only needed if you want the admin pipeline dashboard to show live D1 stats
CLOUDFLARE_API_TOKEN=...
CLOUDFLARE_ACCOUNT_ID=34400e6e147e83e95c942135f54aeba7
CLOUDFLARE_D1_DATABASE_ID=50f5e26a-c794-4cfa-b2b7-2bbd1d7c045c

# ── Cloudflare Worker URLs (optional — pipeline trigger from admin) ───────────
WORKER_A_URL=https://detectai-pipeline.workers.dev
WORKER_B_URL=https://detectai-pipeline-b.workers.dev
WORKER_C_URL=https://detectai-pipeline-c.workers.dev
WORKER_D_URL=https://detectai-pipeline-d.workers.dev
WORKER_E_URL=https://detectai-pipeline-e.workers.dev

# ── HuggingFace Dataset (optional — pipeline push target) ────────────────────
HF_DATASET_REPO=saghi776/detectai-dataset

# ── Internal API Secret (optional — secures internal service-to-service calls) ──
# Generate with: openssl rand -hex 32
INTERNAL_API_SECRET=

# ── Contact form (optional — Resend email on /contact submissions) ────────────
# Get from: https://resend.com → API Keys
RESEND_API_KEY=re_...
