{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "installCommand": "npm ci --legacy-peer-deps",
  "regions": ["iad1", "sin1"],
  "env": {
    "NEXT_TELEMETRY_DISABLED": "1"
  },
  "functions": {
    "app/api/detect/text/route.ts":    { "maxDuration": 60  },
    "app/api/detect/image/route.ts":   { "maxDuration": 60  },
    "app/api/detect/audio/route.ts":   { "maxDuration": 60  },
    "app/api/detect/video/route.ts":   { "maxDuration": 120 },
    "app/api/detect/pdf/route.ts":     { "maxDuration": 120 },
    "app/api/chat/route.ts":           { "maxDuration": 120 },
    "app/api/upload/route.ts":         { "maxDuration": 30  },
    "app/api/inngest/route.ts":        { "maxDuration": 300 },
    "app/api/pipeline/push/route.ts":  { "maxDuration": 300 }
  }
}
